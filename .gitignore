node_modules/

# Build output (Bun bundler). The backend serves apps/web/dist; generated, not tracked.
dist/

# Playwright e2e artefacts (reports, traces) — generated, not tracked.
playwright-report/
test-results/

# Runtime per-clone state — the approval marker etc. The dir is tracked (via README), contents are not.
/.agent-state/*
!/.agent-state/README.md

# Personal Claude Code overrides
/.claude/settings.local.json

# Transient agent worktrees (Agent tool isolation) — never tracked.
/.claude/worktrees/

# Bun project — npm must never leave a lockfile
package-lock.json
